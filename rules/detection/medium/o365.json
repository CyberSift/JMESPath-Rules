[
  {
    "title": "O365 Inbox Rule Created or Modified",
    "expression": "contains(['New-InboxRule', 'Set-InboxRule'], o365.audit.Operation)",
    "severity": "medium",
    "type": "o365"
  },
    {
    "title": "O365 Exchange Anti-Phish Policy Deletion",
    "expression": "event.dataset == 'o365.audit' && event.provider == 'Exchange' && event.category == 'web' && contains(to_string(event.action), 'Remove-AntiPhishPolicy')",
    "severity": "medium",
    "type": "o365"
  },
  {
    "title": "O365 Exchange DLP Policy Removed",
    "expression": "event.dataset=='o365.audit' && event.provider=='Exchange' && event.category=='web' && event.action=='Remove-DlpPolicy' && event.outcome=='success'",
    "severity": "medium",
    "type": "o365"
  },
  {
    "title": "O365 Copilot Jailbreak Attempt Detected",
    "expression": "contains(to_string(o365.audit.CopilotEventData.Messages[].JailbreakDetected), `true`)",
    "severity": "medium",
    "type": "o365",
    "reference": "https://outline.cybersift.io/s/engineering/doc/o365-copilot-jailbreak-attempt-detected-ov5sunR6fe"
  }
]
