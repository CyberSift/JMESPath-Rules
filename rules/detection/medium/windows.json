[
  {
    "title": "Non-existent user login",
    "expression": "to_string(event.code)=='4625' && winlog.event_data.SubStatus=='0xc0000064' && winlog.cybersift.TargetUserType=='user'",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Abnormal Login Source Workstation First Time Seen",
    "expression": "contains(Abnormalities || '', 'AbnormalLoginSource_FirstTimeSeen')",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Abnormal Login Source Workstation Rarely Seen",
    "expression": "contains(to_string(Abnormalities), 'AbnormalLoginSource_RarelySeen') && !(to_string(winlog.event_data.WorkstationName)=='-' || to_string(winlog.cybersift.LogonTypeText)=='Service' || to_string(winlog.event_data.IpAddress)=='127.0.0.1')",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "High Privilege User Login",
    "expression": "contains(Abnormalities || '', 'HighPrivilegeUser')",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Possible Lateral Movement",
    "expression": "contains(Abnormalities || '', 'PossibleLateralMovement')",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Possible NTLM Relay",
    "expression": "contains(Abnormalities || '', 'Possible-NTLM-Relay')",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Abnormal Login Source Workstation",
    "expression": "contains(to_string(Abnormalities), 'AbnormalLoginSource') && !(to_string(winlog.event_data.WorkstationName)=='-' || to_string(winlog.cybersift.LogonTypeText)=='Service' || to_string(winlog.event_data.IpAddress)=='127.0.0.1')",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Disabled User Activity",
    "expression": "winlog.event_data.Status=='0xc0000072' || winlog.event_data.SubStatus=='0xc0000072'",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "nltest Enumeration",
    "expression": "to_string(event.code) == '4688' && (contains(to_string(winlog.event_data.NewProcessName), 'nltest.exe') || contains(to_string(winlog.event_data.CommandLine), 'nltest'))",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "The security log is now full",
    "expression": "to_string(event.code) == '1104' && to_string(winlog.channel) == 'Security'",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "High Risk Binary Executed with Admin Privilige",
    "expression": "to_string(event.code) == '4688' && winlog.event_data.TokenElevationType == '%%1937' && (ends_with(to_string(winlog.event_data.NewProcessName), '\\\\mshta.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\wmic.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\at.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\psexec.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\winrm.cmd') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\winrs.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\bcdedit.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\takeown.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\installutil.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\odbcconf.exe') || ends_with(to_string(winlog.event_data.NewProcessName), '\\\\cmstp.exe'))",
    "severity": "medium",
    "type": "windows"
  },
  {
    "title": "Windows Account Set to Password Never Expires",
    "expression": "(to_string(event.code)=='4738' && to_string(event.action)=='Process Creation') && contains(to_string(winlog.event_data.UserAccountControl), '%%2089')",
    "severity": "medium",
    "type": "windows",
    "reference": "https://outline.cybersift.io/s/engineering/doc/windows-account-set-to-never-expires-h79JXS0EtB"
  },
  {
    "title": "Successful Interactive Logon from Public IP",
    "expression": "to_string(event.code)=='4624' && winlog.cybersift.LoginInfo.PrivateLoginSourceAddress==`false` && starts_with(to_string(winlog.event_data.LogonProcessName), 'User32')",
    "severity": "medium",
    "type": "windows",
    "reference": "https://outline.cybersift.io/s/engineering/doc/successful-interactive-logon-from-public-ip-e2uptELtgV"
  },
  {
    "title": "Windows whoami Privilege Discovery",
    "expression": "to_string(event.code)=='4688' && (contains(to_string(winlog.event_data.CommandLine), 'whoami') && (contains(to_string(winlog.event_data.CommandLine), 'all')) || contains(to_string(winlog.event_data.CommandLine), 'priv'))",
    "severity": "medium",
    "type": "windows",
    "reference": "https://outline.cybersift.io/s/engineering/doc/windows-whoami-privilege-discovery-bJOeWpehMD"
  },
  {
    "title": "Local Administrators Group Enumeration",
    "expression": "to_string(event.code) == '4688' && contains(to_string(winlog.event_data.CommandLine), 'localgroup') && contains(to_string(winlog.event_data.CommandLine), 'administrators')",
    "severity": "medium",
    "type": "windows",
    "reference": "https://outline.cybersift.io/s/6aa4e37d-e158-4062-9841-c5aede4b76a7"
  }
]
