[
  {
    "title": "AWS - Local User Created Outside Identity Provider",
    "expression": "to_string(event.dataset)=='aws.cloudtrail' && (to_string(cybersift.aws.eventName)=='CreateUser' && to_string(cybersift.aws.eventSource)=='iam.amazonaws.com')",
    "severity": "medium",
    "type": "aws",
    "reference": "https://outline.cybersift.io/s/engineering/doc/aws-local-user-created-outside-identity-provider-GKvYW8F9aN"
  },
  {
    "title": "AWS - S3 Bucket Deleted",
    "expression": "to_string(event.dataset)=='aws.cloudtrail' && to_string(cybersift.aws.eventName)=='DeleteBucket'",
    "severity": "medium",
    "type": "aws",
    "reference": "https://outline.cybersift.io/s/engineering/doc/aws-s3-bucket-deleted-5LwdDNTBXQ"
  },
  {
    "title": "AWS API Activity from Uncommon S3 Client",
    "expression": "event.dataset == 'aws.cloudtrail' && (contains(to_string(cybersift.aws.userAgent), 'S3 Browser') || contains(to_string(cybersift.aws.userAgent), 'Cyberduck'))",
    "severity": "medium",
    "type": "aws",
    "reference": "https://outline.cybersift.io/s/8cb26b93-72a6-4f16-a753-310af2c5284e"
  },
  {
    "title": "AWS Account Discovery By Rare User",
    "expression": "event.dataset == 'aws.cloudtrail' && to_string(cybersift.aws.userIdentity.type) != 'AWSService' && ((to_string(cybersift.aws.eventSource) == 'organizations.amazonaws.com' && contains(['DescribeOrganization','DescribeOrgnanizationalUnit','ListAccounts','ListRoots','ListOrganizationalUnitsForParent','ListAccountsForParent','ListPolicies','ListAWSServiceAccessForOrganization','ListDelegatedAdministrators','ListDelegatedServicesForAccount','DescribeResourcePolicy'], to_string(cybersift.aws.eventName))) || (to_string(cybersift.aws.eventSource) == 'iam.amazonaws.com' && contains(['ListAccountAliases','GetAccountSummary'], to_string(cybersift.aws.eventName))))",
    "severity": "medium",
    "type": "aws",
    "reference": "https://outline.cybersift.io/s/2a7cbf90-3596-4c6a-9714-8fb12a92e91d"
  },
  {
    "title": "AWS Suspicious User Agent Fingerprint",
    "expression": "event.dataset == 'aws.cloudtrail' && (contains(to_string(cybersift.aws.userAgent), 'kali') || contains(to_string(cybersift.aws.userAgent), 'TruffleHog') || to_string(cybersift.aws.userAgent), 'trufflehog'))",
    "severity": "medium",
    "type": "aws",
    "reference": "https://outline.cybersift.io/s/9733a16c-5571-4a79-96d1-9c7c9329bb18"
  }
]
