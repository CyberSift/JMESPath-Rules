[
  {
    "title": "Boot/Kernel Configuration Modified",
    "expression": "(to_string(contains(event.category, 'file')) && to_string(contains(event.type, 'change'))) && (contains(to_string(file.path), '/etc/sysctl') || contains(to_string(file.path), '/etc/modules-load.d/') || contains(to_string(file.path), '/etc/modprobe.d/') || contains(to_string(file.path), '/etc/default/grub') || contains(to_string(file.path), '/lib/modules/'))",
    "severity": "high",
    "type": "auditbeat"
  }
]
