[
  {
    "title": "Boot/Kernel Configuration Modified",
    "expression": "contains(to_string(event.category), 'file') && contains(to_string(event.type), 'change') && (contains(to_string(file.path), '/etc/sysctl') || contains(to_string(file.path), '/etc/modules-load.d/') || contains(to_string(file.path), '/etc/modprobe.d/') || contains(to_string(file.path), '/etc/default/grub') || contains(to_string(file.path), '/lib/modules/'))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/bootkernel-configuration-modified-f1ESQrLKv8"
  },
  {
    "title": "Unprivileged AF_ALG Socket Creation",
    "expression": "auditd.message_type=='syscall' && auditd.data.syscall=='socket' && to_string(auditd.data.a0)=='38' && to_string(user.id)!='0'",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/af_alg-socket-creation-by-unprivileged-login-users-VYlxHxQwMi"
  },
  {
    "title": "Splice Syscall",
    "expression": "auditd.message_type=='syscall' && auditd.data.syscall=='splice' && to_string(user.id)!='0'",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/splice-syscall-sDAKxmqFbX"
  },
  {
    "title": "SSH BatchMode Localhost Authentication Check",
    "expression": "contains(to_string(process.title), 'BatchMode=yes') && (contains(to_string(process.title), 'localhost') || contains(to_string(process.title), '127.0.0.1') || contains(to_string(process.title), '::1'))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/2b873580-55fc-4a13-89d5-4450c4b9e36a"
  },
  {
    "title": "AF_ALG Socket Abuse – Kernel Exploitation Indicator",
    "expression": "to_string(auditd.data.syscall) == 'socket' && to_string(auditd.data.a0) == '26'",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/e690b6c8-06fe-4a40-9134-652815152349"
  }
]
