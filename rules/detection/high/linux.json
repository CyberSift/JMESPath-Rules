[
  {
    "title": "Boot/Kernel Configuration Modified",
    "expression": "contains(to_string(event.category), 'file') && contains(to_string(event.type), 'change') && (contains(to_string(file.path), '/etc/sysctl') || contains(to_string(file.path), '/etc/modules-load.d/') || contains(to_string(file.path), '/etc/modprobe.d/') || contains(to_string(file.path), '/etc/default/grub') || contains(to_string(file.path), '/lib/modules/'))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/bootkernel-configuration-modified-f1ESQrLKv8"
  },
  {
    "title": "Unprivileged AF_ALG Socket Creation",
    "expression": "auditd.message_type=='syscall' && auditd.data.syscall=='socket' && to_string(auditd.data.a0)=='38' && to_string(user.id)!='0'",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/af_alg-socket-creation-by-unprivileged-login-users-VYlxHxQwMi"
  },
  {
    "title": "Splice Syscall",
    "expression": "auditd.message_type=='syscall' && auditd.data.syscall=='splice' && to_string(user.id)!='0' && user.name != 'oracle'",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/splice-syscall-sDAKxmqFbX"
  },
  {
    "title": "SSH BatchMode Localhost Authentication Check",
    "expression": "contains(to_string(process.title), 'BatchMode=yes') && (contains(to_string(process.title), 'localhost') || contains(to_string(process.title), '127.0.0.1') || contains(to_string(process.title), '::1'))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/ssh-batchmode-localhost-authentication-check-4zoZbaICUi"
  },
  {
    "title": "AF_ALG Socket Abuse – Kernel Exploitation Indicator",
    "expression": "to_string(auditd.data.syscall) == 'socket' && to_string(auditd.data.a0) == '26'",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/af_alg-socket-abuse-kernel-exploitation-indicator-EIGgeiDgMV"
  },
  {
    "title": "Suspicious Grep of Sensitive Linux Configuration Files",
    "expression": "(contains(to_string(process.title), 'grep')) && ((contains(to_string(process.title), '/etc/passwd')) || (contains(to_string(process.title), '/etc/shadw')))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/suspicious-grep-of-sensitive-linux-configuration-files-eKWes89Bcm"
  },
  {
    "title": "Sensitive Pattern Enumeration in Bash History File",
    "expression": "(to_string(event.action) == 'executed') && (contains(['grep', 'egrep', 'fgrep', 'awk', 'sed'], to_string(process.name))) && (contains(to_string(process.args), 'bash_history') || contains(to_string(process.args), '.sh_history') || contains(to_string(process.args), '.zsh_history')) && (contains(to_string(process.args), 'password') || contains(to_string(process.args), 'passwd') || contains(to_string(process.args), 'token') || contains(to_string(process.args), 'linpeas') || contains(to_string(process.args), 'secret') || contains(to_string(process.args), 'shadow') || contains(to_string(process.args), 'az login'))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/sensitive-pattern-enumeration-in-bash-history-file-qx2U6yZ81t"
  },
  {
    "title": "Linux Privilege Escalation Enumeration Tool Execution",
    "expression": "(to_string(event.action) == 'executed') && (contains(to_string(process.name), 'linpeas') || contains(to_string(process.args), 'linpeas.sh') || contains(to_string(process.title), '/les.sh') || contains(to_string(process.title), 'linux-exploit-suggester'))",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/engineering/doc/linux-privilege-escalation-enumeration-tool-execution-lTcaAQhuMC"
  },
  {
    "title": "Linux SUID File Enumeration",
    "expression": "contains(to_string(process.title), 'find') && contains(to_string(process.title), '-perm') && contains(to_string(process.title), '-4000')",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/dcc57a5d-436b-40aa-ba4e-490ab4c5e7ec"
  },
  {
    "title": "Potential Reverse Shell Interactive TTY Spawned",
    "expression": "contains(to_string(process.title), 'rlwrap') || contains(to_string(process.title), 'pty.spawn')",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/f02784c0-8fc7-4fa7-993c-dca52a001a57"
  },
  {
    "title": "Linux - Temporary Web Server Started",
    "expression": "contains(to_string(process.title),'SimpleHTTPServer') || contains(to_string(process.title),'http.server') || contains(to_string(process.title),'php -S') || contains(to_string(process.title),'npx http-server')",
    "severity": "high",
    "type": "auditbeat",
    "reference": "https://outline.cybersift.io/s/1b8b0fcd-7892-4dff-be83-28f2d6f24ab7"
  }
]
