[
  {
    "title": "Potentially Unauthorized Gmail Route / Message Security Rule Change",
    "expression": "event.dataset == 'google_workspace.admin' && (event.action == 'CREATE_GMAIL_SETTING' || event.action == 'CHANGE_GMAIL_SETTING') && google_workspace.event.type == 'EMAIL_SETTINGS' && (google_workspace.admin.setting.name == 'EMAIL_ROUTE' || google_workspace.admin.setting.name == 'MESSAGE_SECURITY_RULE')",
    "severity": "high",
    "type": "google_workspace",
    "reference": "https://outline.cybersift.io/s/engineering/doc/potentially-unauthorized-gmail-route-message-security-rule-change-5bWrY9ikGH"
  },
  {
    "title": "Google Workspace Admin Role Assigned to a User",
    "expression": "event.dataset == 'google_workspace.admin' && event.category == 'iam' && event.action == 'ASSIGN_ROLE' && google_workspace.event.type == 'DELEGATED_ADMIN_SETTINGS' && ends_with(to_string(google_workspace.admin.role.name), '_ADMIN_ROLE')",
    "severity": "high",
    "type": "google_workspace",
    "reference": "https://outline.cybersift.io/s/engineering/doc/google-workspace-admin-role-assigned-to-a-user-e31qJZSj5D"
  },
  {
    "title": "Google Workspace API Access Granted via Domain-Wide Delegation",
    "expression": "event.dataset == 'google_workspace.admin' && event.provider == 'admin' && event.category == 'iam' && event.action == 'AUTHORIZE_API_CLIENT_ACCESS' && event.outcome == 'success'",
    "severity": "high",
    "type": "google_workspace",
    "reference": "https://outline.cybersift.io/s/engineering/doc/google-workspace-api-access-granted-via-domain-wide-delegation-PUuVHLNgbU"
  }
]
